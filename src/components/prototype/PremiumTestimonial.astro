---
import { premiumTestimonial } from '@/data/interiorRenovationsPrototype';
---

<section class="proto-premium-testimonial reveal" aria-label="Featured homeowner review">
	<div>
		<p class="proto-eyebrow">Client confidence</p>
		<blockquote>"{premiumTestimonial.quote}"</blockquote>
		<cite>
			{premiumTestimonial.name}
			<span>{premiumTestimonial.location}</span>
		</cite>
	</div>
	<a href="/reviews">Read more client reviews</a>
</section>
