---
import { Image } from 'astro:assets';
import { projectTypes, projectTypesSummary } from '@/data/interiorRenovationsPrototype';
---

<section class="proto-project-types">
	<div class="proto-section-head reveal">
		<p class="proto-eyebrow">Project-led planning</p>
		<h2>Start with the project, not the trade</h2>
		<p>
			Clients do not need to determine which contractor handles every item before contacting
			Strataline.
		</p>
	</div>
	<div class="proto-project-panels">
		{
			projectTypes.map((project, index) => (
				<article class="proto-project-panel reveal">
					<div class="proto-project-panel__index">{String(index + 1).padStart(2, '0')}</div>
					<figure>
						<Image
							src={project.image.src}
							alt={project.image.alt}
							widths={[520, 760, 1080]}
							sizes="(max-width: 900px) 100vw, 42vw"
							loading="lazy"
						/>
					</figure>
					<div class="proto-project-panel__copy">
						<h3>{project.title}</h3>
						<p>{project.intro}</p>
					</div>
				</article>
			))
		}
	</div>
	<p class="proto-project-types__summary reveal">{projectTypesSummary}</p>
</section>
