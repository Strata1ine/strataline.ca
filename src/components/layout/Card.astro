---
import type { ImageSource, Pos } from '@/schemas';

interface Props {
	id?: string;
	title: string;
	image: ImageSource;
	videoSrc?: string;
	desc: string;
	pos: Pos;
	link?: string;
	textLink?: string;
}

const meta = Astro.props as Props;

import { cn } from '@/frontend/utils';
import markdown from '@/build/markdown';
import Image from '@/components/Image';

const mediaClass =
	'order-2 aspect-16/10 max-h-65 w-full sm:order-0 sm:max-h-130 sm:min-h-90 sm:w-1/2';

const mediaHoverClass =
	'order-2 aspect-16/10 max-h-65 w-full transition-transform duration-300 group-hover:scale-[1.02] sm:order-0 sm:max-h-130 sm:min-h-90 sm:w-1/2';
---

{
	meta.link ? (
		<a
			href={meta.link}
			class="group block cursor-pointer transition-opacity duration-200 hover:opacity-95"
			id={meta.id}
		>
			<div
				class={cn(
					'flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-8 xl:gap-8 2xl:gap-11',
					meta.pos === 'right' && 'sm:flex-row-reverse',
				)}
			>
				{meta.videoSrc ? (
					<video
						class={mediaHoverClass}
						poster={meta.image.src.src}
						aria-label={meta.image.alt}
						draggable={false}
						playsinline
						muted
						autoplay
						loop
						preload="none"
						controls={false}
						disablepictureinpicture
					>
						<source src={meta.videoSrc} type="video/mp4" />
					</video>
				) : (
					<Image
						class={mediaHoverClass}
						pos={meta.pos}
						image={meta.image}
						widths={[400, 725, 1450]}
					/>
				)}

				<div class="flex flex-col gap-3 sm:flex-1">
					<h3 class="heading-4xl order-1 underline-offset-4 group-hover:underline">{meta.title}</h3>

					<p class="desc-base order-3" set:html={await markdown.parseInline(meta.desc)} />

					<div class="order-4 mt-4">
						<slot />
					</div>
				</div>
			</div>
		</a>
	) : (
		<div
			class={cn(
				'flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-8 xl:gap-8 2xl:gap-11',
				meta.pos === 'right' && 'sm:flex-row-reverse',
			)}
			id={meta.id}
		>
			{meta.videoSrc ? (
				<video
					class={mediaClass}
					poster={meta.image.src.src}
					aria-label={meta.image.alt}
					draggable={false}
					playsinline
					muted
					autoplay
					loop
					preload="none"
					controls={false}
					disablepictureinpicture
				>
					<source src={meta.videoSrc} type="video/mp4" />
				</video>
			) : (
				<Image class={mediaClass} pos={meta.pos} image={meta.image} widths={[400, 725, 1450]} />
			)}

			<div class="flex flex-col gap-3 sm:flex-1">
				{
					meta.textLink ? (
						<>
							<a
								href={meta.textLink}
								class="group/text order-1 block rounded-md transition-colors hover:text-secondary focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-secondary"
							>
								<h3 class="heading-4xl underline-offset-5 group-hover/text:underline">{meta.title}</h3>
							</a>
							<p
								class="desc-base order-3"
								set:html={await markdown.parseInline(meta.desc)}
							/>
						</>
					) : (
						<>
							<h3 class="heading-4xl order-1">{meta.title}</h3>

							<p class="desc-base order-3" set:html={await markdown.parseInline(meta.desc)} />
						</>
					)
				}

				<div class="order-4 mt-4">
					<slot />
				</div>
			</div>
		</div>
	)
}
