---
import { type SchemaOf, createSchema } from 'astro-frontmatter-cms';
import { type SchemaContext } from 'astro:content';
import { z } from 'astro:schema';
import { DefaultPos } from '@/schemas';
import { image } from '@/schemas';

export const schema = createSchema('Gallery', (c: SchemaContext) =>
	z.object({
		id: z.string().optional(),
		title: z.string(),
		pos: DefaultPos,
		content: z.array(image(c)),
	}),
);

export type Props = SchemaOf<typeof schema>;
const meta = Astro.props as Props;

import * as Layout from '@/components/Layout';
import Island from './Gallery';
---

<Layout.Divider>
	<Layout.Title title={meta.title} pos={meta.pos} />
	<Layout.Container variant="outer" class="px-4">
		<Island client:visible content={meta.content} />
	</Layout.Container>
</Layout.Divider>
