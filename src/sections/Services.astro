---
import { type SchemaOf, createSchema } from 'astro-frontmatter-cms';
import { type SchemaContext } from 'astro:content';
import { z } from 'astro:schema';
import { DefaultPos } from '@/schemas';
import { schema as textCarousel } from './TextCarousel.astro';

export const schema = createSchema('Services', (c: SchemaContext) =>
	z.object({
		id: z.string().optional(),
		pos: DefaultPos,
		title: z.string().default(`There's more to see`),
		exclude: z.array(z.string()).optional(),
		content: z
			.object({
				id: z.string().optional(),
				speed: z.number().optional().default(0.1),
				text: z.array(z.string()),
			})
			.optional(),
	}),
);

import { getEntry, getCollection } from '@/content.config';

export type Props = SchemaOf<typeof schema>;
const meta = Astro.props as Props;

let exclude: string[];
if (meta.exclude == undefined) {
	const index = await getEntry('index', 'index');
	exclude = index.data.popular;
} else {
	exclude = meta.exclude;
}

function normalizeServiceId(id: string) {
	return id.replace(/\/index$/, '').replace(/^\/+|\/+$/g, '');
}

function isRootService(id: string) {
	const normalized = normalizeServiceId(id);
	return normalized.split('/').length === 1;
}

function isExcluded(id: string, excludeList: string[]) {
	const normalized = normalizeServiceId(id);
	return excludeList.some((pattern) => normalizeServiceId(pattern) === normalized);
}

const allServices = await getCollection('services');

const services = allServices
	.filter((service) => isRootService(service.id))
	.filter((service) => !isExcluded(service.id, exclude));

import { Icon } from 'astro-icon/components';
import { Image } from '@/components/Image';

import * as Layout from '@/components/Layout';
import Island from './TextCarousel';
---

<Layout.Divider id={meta.id}>
	<div class="bg-primary py-12 md:py-22">
		<Layout.Split pos={meta.pos}>
			<h2 slot="title" class="heading-5xl top-0 sm:sticky">
				{meta.title}
			</h2>

			<div class="flex-2 space-y-6 md:space-y-10 xl:gap-10">
				{
					services.map((service) => {
						const slug = normalizeServiceId(service.id);
						const href = `/services/${slug}`;
						const cardId = slug.replaceAll('/', '-');

						return (
							<a
								class="group block grid cursor-pointer items-stretch gap-4 overflow-hidden rounded-2xl border border-black/10 bg-white p-3 shadow-[0_8px_24px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_32px_rgba(0,0,0,0.08)] md:grid-cols-[minmax(260px,42%)_1fr] md:gap-8 md:p-4"
								href={href}
								id={cardId}
								tabindex="0"
								draggable={false}
							>
								<div class="relative overflow-hidden rounded-xl">
									<Image
										class="aspect-[16/10] w-full transition-transform duration-500 group-hover:scale-105"
										anim="hover"
										image={service.data.image}
										widths={[400, 600, 800, 1200]}
									/>

									<div class="absolute inset-0 bg-gradient-to-t from-black/25 via-black/5 to-transparent opacity-80" />
								</div>

								<div class="flex min-w-0 flex-col justify-center gap-4 px-1 py-1 md:px-2">
									<div class="space-y-2">
										<h3 class="text-2xl leading-tight text-balance underline-offset-4 group-hover:underline sm:text-2xl xl:text-3xl">
											{service.data.title}
										</h3>

										{service.data.desc && (
											<p class="line-clamp-4 text-base leading-relaxed text-black/65 md:text-lg">
												{service.data.desc}
											</p>
										)}
									</div>

									<div class="flex items-center gap-3 pt-2">
										<span class="inline-flex items-center rounded-full border border-black/15 px-4 py-2 text-sm font-medium text-black/80 transition-all duration-200 group-hover:bg-black group-hover:text-white">
											View service
										</span>

										<Icon
											aria-hidden={true}
											class="h-auto w-7 flex-none transition-transform duration-200 group-hover:translate-x-1"
											name="arrow"
											is:inline
										/>
									</div>
								</div>
							</a>
						);
					})
				}
			</div>
		</Layout.Split>
	</div>

	{meta.content && <Island client:visible meta={meta.content} />}
</Layout.Divider>
