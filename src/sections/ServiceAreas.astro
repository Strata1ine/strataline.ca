---
import { type SchemaOf, createSchema } from 'astro-frontmatter-cms';
import { type SchemaContext } from 'astro:content';
import { z } from 'astro:schema';

import * as Layout from '@/components/Layout';
import Actions from '@/components/Actions';
import { getCollection } from '@/content.config';

export const schema = createSchema('ServiceAreas', (_c: SchemaContext) =>
	z.object({
		id: z.string().optional(),
		title: z.string(),
		service: z.string(),
	}),
);

export type Props = SchemaOf<typeof schema>;
const meta = Astro.props as Props;

// Examples:
// /services/wallpaper/toronto -> ['wallpaper', 'toronto']
// /services/stairs/refinishing/toronto -> ['stairs', 'refinishing', 'toronto']
const segments = Astro.url.pathname.split('/').filter(Boolean);
const serviceSegments = segments[0] === 'services' ? segments.slice(1) : segments;
const currentId = serviceSegments.join('/');

const allPages = await getCollection('services');

const isIndexable = (entry: (typeof allPages)[number]) => {
	if (entry.data.hidden === true) return false;
	if (typeof entry.data.seo === 'string') return true;

	return entry.data.seo.noindex !== true && entry.data.seo.indexableQuality !== 'weak';
};

const toLabel = (id: string) => {
	const area = id.replace(`${meta.service}/`, '');

	return area
		.replace(/[_-]/g, ' ')
		.replace(/\b\w/g, (m) => m.toUpperCase());
};

const areaOrder = [
	'toronto',
	'vaughan',
	'richmond-hill',
	'markham',
	'aurora',
	'king-city',
	'kleinburg',
	'stouffville',
	'woodbridge',
	'mississauga',
	'oakville',
	'burlington',
	'etobicoke',
	'ajax',
	'pickering',
	'whitby',
	'oshawa',
	'newmarket',
	'bradford',
	'innisfil',
	'caledon',
	'bolton',
	'forest-hill',
	'rosedale',
	'leaside',
	'the-beaches',
];

const hubPage = allPages.find((entry) => entry.id === meta.service);
const serviceTitle = hubPage?.data.title ?? meta.title;
const serviceLabel =
	meta.title.replace(/\s+service areas$/i, '') ||
	serviceTitle.replace(/\s+-\s+.*$/, '').replace(/\s+in\s+.*$/i, '');
const summaryLabel = `View ${serviceLabel.toLowerCase()} service areas`;

const areaPages = allPages
	.filter((entry) => entry.id.startsWith(`${meta.service}/`))
	.filter((entry) => entry.id !== currentId)
	.filter((entry) => isIndexable(entry))
	.sort((a, b) => {
		const aArea = a.id.replace(`${meta.service}/`, '');
		const bArea = b.id.replace(`${meta.service}/`, '');

		const aIndex = areaOrder.indexOf(aArea);
		const bIndex = areaOrder.indexOf(bArea);

		const aRank = aIndex === -1 ? 999 : aIndex;
		const bRank = bIndex === -1 ? 999 : bIndex;

		if (aRank !== bRank) return aRank - bRank;
		return a.data.title.localeCompare(b.data.title);
	});

const showHubCard = Boolean(hubPage && hubPage.id !== currentId);
const hasServiceAreaLinks = showHubCard || areaPages.length > 0;
---

{
	hasServiceAreaLinks && (
		<Layout.Divider id={meta.id}>
			<Layout.Title title={meta.title} pos="left" />

			<Layout.Container variant="inner">
				<p class="desc-base mb-5 max-w-3xl">
					We serve Toronto, York Region, Peel, Durham, Halton, and nearby GTA communities.
					Open the city list to find local {serviceLabel.toLowerCase()} pages with planning
					notes, FAQs, and quote details.
				</p>

				<details class="service-areas-collapse group">
					<summary class="bg-primary inline-flex min-h-13 cursor-pointer select-none items-center gap-3 rounded-full px-6 py-3 font-sans text-base font-semibold text-black shadow-sm transition hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black sm:text-lg">
						<span>{summaryLabel}</span>
						<span
							class="service-areas-icon flex size-7 items-center justify-center rounded-full bg-white/75 text-xl leading-none transition-transform"
							aria-hidden="true"
						>
							+
						</span>
					</summary>

					<div class="service-area-grid mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{showHubCard && hubPage && (
							<div class="rounded-2xl border border-black/10 bg-white p-5 shadow-sm">
								<h3 class="mb-2 font-serif text-2xl font-semibold">
									{serviceLabel} hub
								</h3>

								<p class="desc-base mb-4">
									See our full {serviceLabel.toLowerCase()} coverage across Toronto and the GTA.
								</p>

								<Actions.Link
									href={`/services/${hubPage.id}`}
									rel="noopener noreferrer"
									data-astro-prefetch=""
								>
									View all service areas
								</Actions.Link>
							</div>
						)}

						{areaPages.map((page) => {
							const label = toLabel(page.id);

							return (
								<div class="rounded-2xl border border-black/10 bg-white p-5 shadow-sm">
									<h3 class="mb-2 font-serif text-2xl font-semibold">{label}</h3>

									<p class="desc-base mb-4">
										See {serviceLabel.toLowerCase()} services in {label}, with local project
										planning, FAQs, and quote information.
									</p>

									<Actions.Link
										href={`/services/${page.id}`}
										rel="noopener noreferrer"
										data-astro-prefetch=""
									>
										{serviceLabel} in {label}
									</Actions.Link>
								</div>
							);
						})}
					</div>
				</details>
			</Layout.Container>
		</Layout.Divider>
	)
}

<style>
	.service-areas-collapse > summary {
		list-style: none;
	}

	.service-areas-collapse > summary::-webkit-details-marker {
		display: none;
	}

	.service-areas-collapse:not([open]) > .service-area-grid {
		display: none;
	}

	.service-areas-collapse[open] .service-areas-icon {
		transform: rotate(45deg);
	}
</style>
