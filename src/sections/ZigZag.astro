---
import { type SchemaOf, createSchema } from 'astro-frontmatter-cms';
import { type SchemaContext } from 'astro:content';
import { z } from 'astro:schema';
import { image, DefaultPos, swapPos } from '@/schemas';

export const schema = createSchema('ZigZag', (c: SchemaContext) =>
	z.object({
		id: z.string().optional(),
		pos: DefaultPos,
		title: z.string(),
		content: z.array(
			z.object({
				title: z.string(),
				desc: z.string(),
				image: image(c),
			}),
		),
	}),
);

export type Props = SchemaOf<typeof schema>;
const meta = Astro.props as Props;
let next = swapPos(meta.pos);

import * as Layout from '@/components/Layout';
---

<Layout.Divider id={meta.id}>
	<Layout.Title title={meta.title} pos={meta.pos} />

	<Layout.Container variant="outer" class="space-y-20 sm:space-y-35">
		{
			meta.content.map((zig, _) => {
				next = swapPos(next);
				return <Layout.Card image={zig.image} title={zig.title} desc={zig.desc} pos={next} />;
			})
		}
	</Layout.Container>
</Layout.Divider>
