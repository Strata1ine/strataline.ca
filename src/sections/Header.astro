---
import { Icon } from 'astro-icon/components';
import Island from './Header';

import { type SchemaOf, createSchema } from 'astro-frontmatter-cms';
import { type SchemaContext } from 'astro:content';
import { z } from 'astro:schema';

export const schema = createSchema('Header', (_: SchemaContext) => z.object({
	content: z.array(z.object({ id: z.string().optional(), href: z.string().optional(), name: z.string() })),
}));

import * as Layout from '@/components/Layout';
export type Props = SchemaOf<typeof schema>;
const meta = Astro.props as Props;
---

<header class="contents">
	<div class="contact-bar sticky top-0 z-50 py-2 text-white shadow-sm">
		<Layout.Container
			variant="inner"
			class="flex items-center justify-between gap-x-1 gap-y-2 px-2 font-sans text-[10px] font-semibold min-[380px]:gap-x-2 min-[380px]:text-xs sm:gap-x-4 sm:px-4 sm:text-base"
		>
			<a
				href="/"
				class="mini-logo-link flex shrink-0 items-center rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary"
				aria-label="Strataline home"
			>
				<img
					src="/strataline-logo-S-small.png"
					alt=""
					width="100"
					height="100"
					class="size-7 rounded-full min-[380px]:size-9 sm:size-11"
				/>
			</a>

			<div class="relative inline-flex min-w-0 items-center">
				<Island client:visible content={meta.content} />
			</div>
		</Layout.Container>
	</div>

	<Layout.Container variant="inner" class="flex items-center py-3">
		<div class="main-logo-sentinel">
			<a href="/" class="main-logo-link block rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-secondary" aria-label="Strataline home">
				<Icon
					name="logo"
					class="text-secondary h-auto w-30 sm:w-40 xl:w-50"
					is:inline
				/>
			</a>
		</div>
	</Layout.Container>
</header>
