---
import PrototypeLayout from '@/layouts/PrototypeLayout.astro';
import PrototypeHeader from '@/components/prototype/PrototypeHeader.astro';
import PrototypeSubnav from '@/components/prototype/PrototypeSubnav.astro';
import PrototypeFooter from '@/components/prototype/PrototypeFooter.astro';
import EditorialHero from '@/components/prototype/EditorialHero.astro';
import FeaturedMediaProof from '@/components/prototype/FeaturedMediaProof.astro';
import RecentWorkGallery from '@/components/prototype/RecentWorkGallery.astro';
import BeforeAfterComparison from '@/components/prototype/BeforeAfterComparison.astro';
import ServiceChooser from '@/components/prototype/ServiceChooser.astro';
import ProcessSequence from '@/components/prototype/ProcessSequence.astro';
import OwnerLedTrust from '@/components/prototype/OwnerLedTrust.astro';
import InteriorRenovationFaq from '@/components/prototype/InteriorRenovationFaq.astro';
import ConsultationCTA from '@/components/prototype/ConsultationCTA.astro';
import { prototypeImages, serviceAreas } from '@/data/interiorRenovationsPrototype';

const title = 'Interior Renovations Toronto & GTA | Strataline';
const description =
	'Coordinated interior renovations in Toronto and the GTA, including ceilings, painting, flooring, stairs, trim, doors, cabinetry, kitchens, bathrooms and dust-controlled finishing work.';

const pageUrl = 'https://strataline.ca/interior-renovations';
const organizationId = 'https://strataline.ca/#organization';
const serviceId = `${pageUrl}#service`;
const schemas = [
	{
		'@type': 'WebPage',
		'@id': `${pageUrl}#webpage`,
		url: pageUrl,
		name: title,
		description,
		isPartOf: { '@id': 'https://strataline.ca/#website' },
		about: { '@id': serviceId },
		provider: { '@id': organizationId },
	},
	{
		'@type': 'Service',
		'@id': serviceId,
		name: 'Interior Renovations',
		url: pageUrl,
		serviceType: 'Interior Renovation',
		provider: { '@id': organizationId },
		areaServed: serviceAreas.map((name) => ({ '@type': 'Place', name })),
		description,
	},
	{
		'@type': 'BreadcrumbList',
		'@id': `${pageUrl}#breadcrumb`,
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Home',
				item: 'https://strataline.ca/',
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: 'Interior Renovations',
				item: pageUrl,
			},
		],
	},
];
---

<PrototypeLayout
	title={title}
	description={description}
	image="/strataline-og.jpg"
	canonicalPath="/interior-renovations"
	schemas={schemas}
>
	<div class="proto-page" id="top">
		<PrototypeHeader />
		<PrototypeSubnav />

		<main>
			<EditorialHero image={prototypeImages.hero} />

			<FeaturedMediaProof />

			<RecentWorkGallery />

			<BeforeAfterComparison />

			<ServiceChooser />

			<ProcessSequence />

			<OwnerLedTrust />

			<InteriorRenovationFaq />

			<section class="proto-service-area section-anchor reveal" id="service-area">
				<p class="proto-eyebrow">Service area</p>
				<h2>Interior renovation services throughout Toronto and the GTA</h2>
				<p>
					Strataline supports occupied homes, pre-move-in work and coordinated interior projects
					across Toronto and surrounding GTA communities.
				</p>
				<ul class="proto-area-list" aria-label="Primary service areas">
					{serviceAreas.map((area) => <li>{area}</li>)}
				</ul>
				<p class="proto-service-area__note">
					Not sure whether your property is within our service area? Send the address with your
					project details.
				</p>
			</section>

			<ConsultationCTA />
		</main>

		<PrototypeFooter />

		<div class="proto-mobile-contact" data-mobile-contact>
			<a href="tel:+14164715999" data-track-event="mobile_phone_click">Call</a>
			<a href="#consultation" data-track-event="mobile_quote_click">Request Quote</a>
		</div>
	</div>

	<script is:inline>
		const header = document.querySelector('[data-prototype-header]');
		const menuButton = document.querySelector('[data-menu-toggle]');
		const menu = document.querySelector('[data-mobile-menu]');
		const subnav = document.querySelector('[data-prototype-subnav]');
		const subnavLinks = [...document.querySelectorAll('[data-subnav-link]')];
		const revealEls = [...document.querySelectorAll('.reveal')];
		const hero = document.getElementById('overview');
		const contactBar = document.querySelector('[data-mobile-contact]');
		const consultation = document.getElementById('consultation');
		const footer = document.querySelector('.proto-footer');
		const sectionIds = subnavLinks
			.map((link) => link.getAttribute('href')?.slice(1))
			.filter(Boolean);
		const sections = sectionIds.map((id) => document.getElementById(id)).filter(Boolean);
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let ticking = false;
		let activeId = '';
		let manualActiveUntil = 0;
		const contactVisibility = { consultation: false, footer: false };

		const setHeaderState = () => {
			header?.classList.toggle('is-scrolled', window.scrollY > 16);
			if (hero && subnav) {
				const threshold = hero.offsetTop + hero.offsetHeight * 0.6;
				const visible = window.scrollY > threshold;
				subnav.classList.toggle('is-visible', visible);
				subnav.setAttribute('aria-hidden', String(!visible));
			}
		};

		const stickyOffset = () => {
			const headerHeight =
				header instanceof HTMLElement ? header.getBoundingClientRect().height : 0;
			const subnavHeight =
				subnav instanceof HTMLElement && subnav.classList.contains('is-visible')
					? subnav.getBoundingClientRect().height
					: 0;
			return headerHeight + subnavHeight + 16;
		};

		const setActiveSection = (id, options = {}) => {
			if (!id) return;
			activeId = id;
			subnavLinks.forEach((link) => {
				const isActive = link.getAttribute('href') === `#${id}`;
				link.classList.toggle('is-active', isActive);
				if (isActive) {
					link.setAttribute('aria-current', 'location');
					if (options.scrollLink !== false) {
						link.scrollIntoView({
							inline: 'center',
							block: 'nearest',
							behavior: reducedMotion ? 'auto' : 'smooth',
						});
					}
				} else {
					link.removeAttribute('aria-current');
				}
			});
		};

		const currentSectionId = () => {
			const documentElement = document.documentElement;
			const nearBottom =
				window.scrollY + window.innerHeight >=
				documentElement.scrollHeight - Math.max(24, window.innerHeight * 0.04);
			if (nearBottom) return 'consultation';
			if (
				consultation instanceof HTMLElement &&
				consultation.getBoundingClientRect().top <=
					Math.min(window.innerHeight * 0.72, stickyOffset() + 240)
			) {
				return 'consultation';
			}

			const boundary = stickyOffset();
			let current = sections[0]?.id ?? '';

			for (const section of sections) {
				const rect = section.getBoundingClientRect();
				if (rect.top <= boundary + 8) {
					current = section.id;
				} else {
					break;
				}
			}

			return current;
		};

		const updateActiveSection = () => {
			ticking = false;
			if (Date.now() < manualActiveUntil && activeId) return;
			const hashId = window.location.hash.slice(1);
			if (hashId && sectionIds.includes(hashId)) {
				const target = document.getElementById(hashId);
				if (target) {
					const rect = target.getBoundingClientRect();
					if (rect.top < window.innerHeight * 0.68 && rect.bottom > stickyOffset()) {
						setActiveSection(hashId);
						return;
					}
				}
			}
			setActiveSection(currentSectionId());
		};

		const requestActiveUpdate = () => {
			if (ticking) return;
			ticking = true;
			window.requestAnimationFrame(updateActiveSection);
		};

		menuButton?.addEventListener('click', () => {
			const expanded = menuButton.getAttribute('aria-expanded') === 'true';
			menuButton.setAttribute('aria-expanded', String(!expanded));
			if (menu) menu.hidden = expanded;
		});

		menu?.addEventListener('click', (event) => {
			const target = event.target;
			if (target instanceof HTMLAnchorElement) {
				menu.hidden = true;
				menuButton?.setAttribute('aria-expanded', 'false');
			}
		});

		if (!reducedMotion) {
			const revealObserver = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							revealObserver.unobserve(entry.target);
						}
					}
				},
				{ rootMargin: '0px 0px -12% 0px', threshold: 0.12 },
			);
			revealEls.forEach((element) => revealObserver.observe(element));
		} else {
			revealEls.forEach((element) => element.classList.add('is-visible'));
		}

		subnavLinks.forEach((link) => {
			link.addEventListener('click', (event) => {
				const id = link.getAttribute('href')?.slice(1);
				if (id) {
					const target = document.getElementById(id);
					if (target) {
						event.preventDefault();
						window.history.pushState(null, '', `#${id}`);
						target.scrollIntoView({
							block: 'start',
							behavior: reducedMotion ? 'auto' : 'smooth',
						});
					}
					manualActiveUntil = Date.now() + 2800;
					setActiveSection(id);
				}
			});
		});

		if (contactBar && 'IntersectionObserver' in window) {
			const updateContactBar = () => {
				contactBar.classList.toggle(
					'is-hidden',
					contactVisibility.consultation || contactVisibility.footer,
				);
			};
			const contactObserver = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.target === consultation)
							contactVisibility.consultation = entry.isIntersecting;
						if (entry.target === footer) contactVisibility.footer = entry.isIntersecting;
					}
					updateContactBar();
				},
				{ threshold: 0.15 },
			);
			if (consultation) contactObserver.observe(consultation);
			if (footer) contactObserver.observe(footer);
		}

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			const tracked = target.closest('[data-track-event]');
			if (!(tracked instanceof HTMLElement)) return;
			window.trackProtoEvent?.(tracked.dataset.trackEvent ?? 'prototype_click');
		});

		setHeaderState();
		if (window.location.hash && sectionIds.includes(window.location.hash.slice(1))) {
			setActiveSection(window.location.hash.slice(1), { scrollLink: false });
		} else {
			setActiveSection(currentSectionId(), { scrollLink: false });
		}
		window.addEventListener('scroll', setHeaderState, { passive: true });
		window.addEventListener('scroll', requestActiveUpdate, { passive: true });
		window.addEventListener('resize', requestActiveUpdate);
		window.addEventListener('load', () => {
			const id = window.location.hash.slice(1);
			if (sectionIds.includes(id)) {
				setActiveSection(id, { scrollLink: false });
			} else {
				requestActiveUpdate();
			}
		});
		window.addEventListener('hashchange', () => {
			const id = window.location.hash.slice(1);
			if (sectionIds.includes(id)) setActiveSection(id);
			else requestActiveUpdate();
		});
	</script>
</PrototypeLayout>
