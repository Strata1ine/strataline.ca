---
import globalStyles from '@/styles/global.css?url';
import { Font } from 'astro:assets';
import business from '#/business.json';
import socials from '#/socials.json';
import { type Pos, isPos, swapPos } from '@/schemas';

import { Frontmatter } from 'astro-frontmatter-cms';
import Footer from '@/sections/Footer.astro';
import Header, { schema as headerSchemas } from '@/sections/Header.astro';

import { queryBlocks, type SchemaMeta } from 'astro-frontmatter-cms';
import { schema as reviewSchemas } from '@/sections/Reviews.astro';
import { schema as faqSchemas, seo as seoFaqs } from '@/sections/Faq.astro';
import { schema as cardshowSchemas, seo as seoCardshows } from '@/sections/Cardshow.astro';

const isProd = import.meta.env.PROD;

interface Props {
	title: string;
	desc?: string;
	blocks?: SchemaMeta[];
	startPos?: Pos;
	schemas?: any[] | any;
	noIndex?: boolean;
}

const pngIcons = await import('@/pages/manifest.json.ts').then((m) => m.pngIcons);

const { title, desc, startPos, blocks, noIndex = false, schemas: rawSchemas = [] } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const canonicalUrl = `${Astro.url.origin}${pathname || '/'}`;
const schemas = [rawSchemas].flat();
let pos = startPos ?? 'right';

const [header] = queryBlocks(blocks, headerSchemas);
const frontmatterBlocks = blocks?.filter((block) => block.type !== 'Header');

const headerContent = header?.content ?? [
	{ href: 'https://strataline.ca/services/popcorn-removal', name: 'Popcorn Removal' },
	{ href: 'https://strataline.ca/services/stairs', name: 'Stairs & Railing' },
	{ href: 'https://strataline.ca/services/doors_and_windows', name: 'Doors & Windows' },
	{ href: 'https://strataline.ca/services/painting', name: 'Painting' },
	{ href: '/reviews', name: '★★★★★ Reviews' },
];

const schema = {
	'@id': `${Astro.url.origin}#company`,
	'@context': 'https://schema.org',
	...business,

	image: {
		'@type': 'ImageObject',
		url: `${Astro.url.origin}/strataline-og.jpg`,
		width: 1200,
		height: 630,
	},

	sameAs: [...business.sameAs, ...socials.map((social) => social.url)],
};

// Keep reviews visible on-page, but do not output Review/AggregateRating JSON-LD.
// Google restricts self-serving review snippets on LocalBusiness/Service pages.
const reviews = queryBlocks(blocks, reviewSchemas);

const faqs = queryBlocks(blocks, faqSchemas);

if (faqs.length > 0) {
	schemas.push(await seoFaqs(Astro, faqs));
}

const cardshow = queryBlocks(blocks, cardshowSchemas);

if (cardshow.length > 0) {
	// WARNING: Keep this server-side only. Do not move this into client code.
	schemas.push(...(await seoCardshows(import.meta.env.YOUTUBE_API_KEY, cardshow)));
}
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		{noIndex && <meta name="robots" content="noindex, nofollow" />}

		<title>
			{title ? `${title} | ${business.name}` : business.name}
		</title>

		<link rel="canonical" href={canonicalUrl} />
		<meta name="description" content={desc} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<link rel="stylesheet" href={globalStyles} />
		<Font cssVariable="--font-cormorant-garamond" />
		<Font cssVariable="--font-inter" />

		<script src="@/frontend/index.ts"></script>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="manifest" href="/manifest.json" />

		{
			pngIcons.map((icon: any) => (
				<>
					<link rel="apple-touch-icon" sizes={icon.sizes} href={icon.src} />
					<link rel="icon" type="image/png" sizes={icon.sizes} href={icon.src} />
				</>
			))
		}

		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify(schema)}
		/>

		{
			schemas.map((schema) => (
				<script
					is:inline
					type="application/ld+json"
					set:html={JSON.stringify({
						'@context': 'https://schema.org',
						...schema,
					})}
				/>
			))
		}

		{
			isProd && (
				<>
					<script
						is:inline
						src="https://analytics.ahrefs.com/analytics.js"
						data-key="HvLQm3PHR0ElL+Vu8t6KBg"
						async
					/>

					<script
						is:inline
						async
						src="https://www.googletagmanager.com/gtag/js?id=G-P421REBVZG"
					></script>

					<script is:inline>
						window.dataLayer = window.dataLayer || [];

						function gtag() {
							dataLayer.push(arguments);
						}

						gtag('js', new Date());
						gtag('config', 'G-P421REBVZG');
					</script>
				</>
			)
		}
	</head>

	<body>
		<Header content={headerContent} />

		<slot />

		<Frontmatter
			callback={(data, i) => {
				if (isPos(data.pos)) {
					data.pos = pos;
					pos = swapPos(pos);
				}

				if (i === 0) {
					if (data.id !== undefined) {
						data.id = `${data.id} intro`;
					} else {
						data.id = 'intro';
					}
				}
			}}
			blocks={frontmatterBlocks}
		/>

		<Footer />
	</body>
</html>
